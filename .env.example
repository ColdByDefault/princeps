POSTGRES_USER=seesweet
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=seesweet

DATABASE_URL=postgresql://seesweet:changeme_use_a_strong_password@localhost:5432/seesweet

# Better Auth
BETTER_AUTH_SECRET=generate_a_random_secret_here
BETTER_AUTH_URL=http://localhost:3000

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Azure AI (production LLM)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=

# Azure Speech (currently unused)
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_ENDPOINT=
# AZURE_SPEECH_REGION=

# Ollama (local dev only, not in Docker)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_EMBED_MODEL=qwen3-embedding:8b
EMBED_DIMENSIONS=4096

# Upload tier limits (defaults baked into tiers.logic.ts — override here if needed)
# Format: "maxFileSizeMB/maxDocs"
# UPLOAD_LIMIT_FREE=2/10
# UPLOAD_LIMIT_PRO=5/25
# UPLOAD_LIMIT_PREMIUM=10/100

# Default admin account
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change_this_admin_password
DEFAULT_ADMIN_NAME=Administrator
DEFAULT_ADMIN_TIER=premium

