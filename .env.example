# Development
#NODE_ENV="development"
#FORCE_GREETING=true 

# Production
#NODE_ENV="production"
FORCE_GREETING=false
#------------------------------------
# Langfuse — LLM observability (production only; ignored in development)
# Sign up at https://cloud.langfuse.com or provide LANGFUSE_HOST for self-hosted.
#LANGFUSE_PUBLIC_KEY="pk-lf-..."
#LANGFUSE_SECRET_KEY="sk-lf-..."
#LANGFUSE_HOST="https://cloud.langfuse.com"
#-----------------------------------
# Docker Compose
POSTGRES_USER="princeps"
POSTGRES_PASSWORD="<YourPasswordHere>"
POSTGRES_DB="princeps"
#-----------------------------------
# Prisma loads this via dotenv in prisma.config.ts
DATABASE_URL="postgresql://princeps:<YourPasswordHere>@localhost:5432/princeps"
#-----------------------------------
# Better Auth
BETTER_AUTH_SECRET="<YourSecretHere>"
BETTER_AUTH_URL="http://localhost:3000"
#-----------------------------------
# Chat provider: "OpenAi" (API) | "ollama" (local) | "groq" (API)
# Default Provider: OpenAI (ChatGPT)
CHAT_PROVIDER="openAi"
#CHAT_PROVIDER="groq"
#CHAT_PROVIDER="ollama"
#-----------------------------------
# OpenAI (API)
OPENAI_API_KEY="<YourOpenAIAPIKeyHere>"
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
#OPENAI_BASE_URL="https://api.openai.com/v1"
#-----------------------------------
# Ollama (local)
#OLLAMA_BASE_URL="http://localhost:11434"
# defaults:
#OLLAMA_CHAT_MODEL="qwen3.5:4b"
#Embedding model (must be compatible with chosen provider)
#OLLAMA_EMBEDDING_MODEL="qwen3-embedding:8b"
#-----------------------------------
# Groq (API)
#GROQ_API_KEY="<YourGroqAPIKeyHere>"
# Available models: Configured from Groq Website > Settings > Limits
#GROQ_MODEL="openai/gpt-oss-120b"
#GROQ_MODEL="llama-3.1-8b-instant"
# Google API (calender only now)
#-----------------------------------
# Integrations and Third-party APIs
GOOGLE_CLIENT_ID="<YourClientIDHere>"
GOOGLE_CLIENT_SECRET="<YourClientSecretHere>"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/google/callback"
