generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────

enum UserRole {
  user
  admin
}

enum UserTier {
  free
  pro
  premium
  enterprise
}

enum MessageRole {
  user
  assistant
}

enum NotificationSource {
  assistant
  system
}

enum TaskStatus {
  open
  in_progress
  done
  cancelled
}

enum TaskPriority {
  low
  normal
  high
  urgent
}

enum DecisionStatus {
  open
  decided
  reversed
}

enum MeetingStatus {
  upcoming
  done
  cancelled
}

enum GoalStatus {
  open
  in_progress
  done
  cancelled
}

enum InteractionSource {
  meeting
  task
}

// ─── Better Auth tables ───────────────────────────────────

model User {
  id                   String   @id @default(cuid())
  name                 String?
  username             String?  @unique
  email                String   @unique
  emailVerified        Boolean  @default(false)
  image                String?
  timezone             String   @default("UTC")
  role                 UserRole @default(user)
  tier                 UserTier @default(free)
  knowledgeCharsUsed   Int      @default(0)
  knowledgeUploadsUsed Int      @default(0)
  preferences          Json     @default("{}")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  sessions           Session[]
  accounts           Account[]
  chats              Chat[]
  notifications      Notification[]
  knowledgeDocuments KnowledgeDocument[]
  knowledgeChunks    KnowledgeChunk[]
  personalInfo       PersonalInfo?
  contacts           Contact[]
  meetings           Meeting[]
  tasks              Task[]
  assistantReports   AssistantReport[]
  decisions          Decision[]
  goals              Goal[]
  briefingCache      BriefingCache?
  shareTokens        ShareToken[]
  integrations       Integration[]
  labels             Label[]
  usageCounter       UsageCounter?

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ─── Chat ─────────────────────────────────────────────────

model Chat {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("New chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@map("chat")
}

model ChatMessage {
  id        String      @id @default(cuid())
  chatId    String
  role      MessageRole
  content   String
  thinking  String? // stored for audit; never rendered in the UI
  createdAt DateTime    @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@map("chat_message")
}

// ─── Notifications ─────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  category  String // e.g. "welcome_signup" | "welcome_login" | "system" | "token_limit"
  source    NotificationSource @default(assistant)
  title     String
  body      String
  read      Boolean  @default(false)
  dismissed Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dismissed, createdAt(sort: Desc)])
  @@map("notification")
}

// ─── Knowledge Base ───────────────────────────────────────

model KnowledgeDocument {
  id        String   @id @default(cuid())
  userId    String
  name      String // original filename — display only, never stored as file
  charCount Int // total chars contributed to quota
  createdAt DateTime @default(now())

  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks     KnowledgeChunk[]
  labelLinks LabelOnKnowledgeDocument[]

  @@index([userId])
  @@map("knowledge_document")
}

model KnowledgeChunk {
  id         String                       @id @default(cuid())
  documentId String
  userId     String
  content    String
  embedding  Unsupported("vector(1536)")?
  chunkIndex Int
  createdAt  DateTime                     @default(now())

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("knowledge_chunk")
}

// ─── Personal Info ────────────────────────────────────────

model PersonalInfo {
  id        String   @id @default(cuid())
  userId    String   @unique
  fields    Json     @default("{}")
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("personal_info")
}

// ─── Contacts ─────────────────────────────────────────────

model Contact {
  id          String    @id @default(cuid())
  userId      String
  name        String
  role        String?
  company     String?
  email       String?
  phone       String?
  notes       String?
  lastContact DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  meetings     MeetingParticipant[]
  interactions ContactInteraction[]
  labelLinks   LabelOnContact[]

  @@index([userId])
  @@map("contact")
}

model ContactInteraction {
  id        String            @id @default(cuid())
  contactId String
  source    InteractionSource
  sourceId  String
  createdAt DateTime          @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([sourceId])
  @@map("contact_interaction")
}

// ─── Meetings ─────────────────────────────────────────────

model Meeting {
  id            String   @id @default(cuid())
  userId        String
  title         String
  scheduledAt   DateTime
  durationMin   Int?
  location      String?
  agenda        String?
  summary       String?
  prepPack      String?
  status        MeetingStatus @default(upcoming)
  googleEventId String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants MeetingParticipant[]
  tasks        Task[]
  decisions    Decision[]
  labelLinks   LabelOnMeeting[]

  @@index([userId])
  @@index([userId, scheduledAt])
  @@map("meeting")
}

model MeetingParticipant {
  id        String @id @default(cuid())
  meetingId String
  contactId String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([meetingId, contactId])
  @@map("meeting_participant")
}

// ─── Assistant Reports ────────────────────────────────────

model AssistantReport {
  id          String   @id @default(cuid())
  userId      String
  toolsCalled Json // string[] — ordered list of tool names that were invoked
  summary     String // LLM-generated brief description of what was done
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("assistant_report")
}

// ─── Tasks ────────────────────────────────────────────────

model Task {
  id        String    @id @default(cuid())
  userId    String
  title     String
  notes     String?
  status    TaskStatus   @default(open)
  priority  TaskPriority @default(normal)
  dueDate   DateTime?
  meetingId String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  meeting Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  labelLinks LabelOnTask[]
  goalLinks  TaskOnGoal[]

  @@index([userId])
  @@index([meetingId])
  @@map("task")
}

// ─── Decisions ────────────────────────────────────────────

model Decision {
  id        String    @id @default(cuid())
  userId    String
  title     String
  rationale String?
  outcome   String?
  status    DecisionStatus @default(open)
  decidedAt DateTime?
  meetingId String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  meeting Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  labelLinks LabelOnDecision[]

  @@index([userId])
  @@index([meetingId])
  @@map("decision")
}

model BriefingCache {
  id          String   @id @default(cuid())
  userId      String   @unique
  content     String
  generatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("briefing_cache")
}

model UsageCounter {
  id                   String  @id @default(cuid())
  userId               String  @unique
  // Daily burst guards
  chatsDailyCount      Int     @default(0)
  chatsDailyDate       String? // "YYYY-MM-DD" UTC — reset boundary for chatsDailyCount
  // Widget dailies (untouched — widget not yet refactored)
  widgetChatsCount     Int     @default(0)
  widgetToolsCount     Int     @default(0)
  widgetCountsDate     String? // "YYYY-MM-DD" UTC — reset boundary for widget counters
  // Monthly quotas (primary limits)
  messageMonthlyCount  Int     @default(0)
  tokenMonthlyCount    Int     @default(0)
  toolMonthlyCount     Int     @default(0)
  monthlyResetDate     String? // "YYYY-MM" UTC — reset boundary for monthly counters

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("usage_counter")
}

model ShareToken {
  id        String   @id @default(cuid())
  userId    String
  fields    Json // string[] of shareable field keys
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("share_token")
}

// ─── Integrations ─────────────────────────────────────────

model Integration {
  id           String    @id @default(cuid())
  userId       String
  provider     String    // "google_calendar"
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("integration")
}

model Label {
  id             String   @id @default(cuid())
  userId         String
  name           String
  color          String   @default("#6366f1")
  icon           String?
  normalizedName String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts  LabelOnContact[]
  meetings  LabelOnMeeting[]
  tasks     LabelOnTask[]
  decisions LabelOnDecision[]
  goals     LabelOnGoal[]
  knowledge LabelOnKnowledgeDocument[]

  @@unique([userId, normalizedName])
  @@index([userId])
  @@map("label")
}

model LabelOnContact {
  labelId   String
  contactId String

  label   Label   @relation(fields: [labelId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([labelId, contactId])
  @@map("label_on_contact")
}

model LabelOnMeeting {
  labelId   String
  meetingId String

  label   Label   @relation(fields: [labelId], references: [id], onDelete: Cascade)
  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@id([labelId, meetingId])
  @@map("label_on_meeting")
}

model LabelOnTask {
  labelId String
  taskId  String

  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)
  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([labelId, taskId])
  @@map("label_on_task")
}

model LabelOnDecision {
  labelId    String
  decisionId String

  label    Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)
  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@id([labelId, decisionId])
  @@map("label_on_decision")
}

model LabelOnKnowledgeDocument {
  labelId    String
  documentId String

  label    Label             @relation(fields: [labelId], references: [id], onDelete: Cascade)
  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([labelId, documentId])
  @@map("label_on_knowledge_document")
}

// ─── Goals ────────────────────────────────────────────────

model Goal {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  status      GoalStatus @default(open)
  targetDate  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones Milestone[]
  taskLinks  TaskOnGoal[]
  labelLinks LabelOnGoal[]

  @@index([userId])
  @@map("goal")
}

model Milestone {
  id        String   @id @default(cuid())
  goalId    String
  title     String
  completed Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("milestone")
}

model TaskOnGoal {
  goalId String
  taskId String

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([goalId, taskId])
  @@map("task_on_goal")
}

model LabelOnGoal {
  labelId String
  goalId  String

  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)
  goal  Goal  @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@id([labelId, goalId])
  @@map("label_on_goal")
}
