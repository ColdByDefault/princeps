  "tools": {
    "title": "Available Tools",
    "description": "Phrases you can say to the assistant to trigger each capability.",
    "groups": {
      "tasks": "Tasks",
      "labels": "Labels",
      "profile": "Profile",
      "contacts": "Contacts"
    },
    "catalog": {
      "create_task": {
        "label": "Create Task",
        "what": "Creates a new task with optional priority, due date, and labels.",
        "example": "\"Add a task: review the Q2 report, high priority, due Friday\""
      },
      "list_tasks": {
        "label": "List Tasks",
        "what": "Retrieves your tasks, optionally filtered by status.",
        "example": "\"What tasks do I have open?\" or \"Show me all urgent tasks\""
      },
      "complete_task": {
        "label": "Complete Task",
        "what": "Marks a task as done.",
        "example": "\"Mark the Q2 report task as done\""
      },
      "update_task": {
        "label": "Update Task",
        "what": "Changes a task's title, notes, priority, due date, status, or labels.",
        "example": "\"Change the report task to urgent and move the due date to Monday\""
      },
      "create_label": {
        "label": "Create Label",
        "what": "Creates a new global label with an optional color.",
        "example": "\"Create a label called Work in blue\""
      },
      "list_labels": {
        "label": "List Labels",
        "what": "Lists all your labels.",
        "example": "\"What labels do I have?\""
      },
      "update_label": {
        "label": "Update Label",
        "what": "Renames or recolors an existing label.",
        "example": "\"Rename the Work label to Professional\""
      },
      "delete_label": {
        "label": "Delete Label",
        "what": "Deletes a label and removes it from all attached records.",
        "example": "\"Delete the label called Old\""
      },
      "get_user_info": {
        "label": "Get My Info",
        "what": "Returns your profile details: name, email, plan, timezone, and member since date.",
        "example": "\"What plan am I on?\" or \"Show me my profile info\""
      },
      "create_contact": {
        "label": "Create Contact",
        "what": "Creates a new contact with optional role, company, email, phone, notes, and labels.",
        "example": "\"Add a contact: Jane Doe, CEO at Acme, jane@acme.com\""
      },
      "list_contacts": {
        "label": "List Contacts",
        "what": "Retrieves all your contacts with their details and IDs.",
        "example": "\"Show me all my contacts\" or \"Who are my contacts?\""
      },
      "update_contact": {
        "label": "Update Contact",
        "what": "Updates an existing contact's details or labels.",
        "example": "\"Update Jane's phone number to +1-555-0100\""
      },
      "delete_contact": {
        "label": "Delete Contact",
        "what": "Permanently deletes a contact.",
        "example": "\"Delete the contact Jane Doe\""
      }
    }
  },
